# Copy this file to .env and adjust values as needed.
# The defaults below work for local development with docker compose.

# PostgreSQL
POSTGRES_USER=nextpost
POSTGRES_PASSWORD=nextpost
POSTGRES_DB=nextpost

# Backend — connection string used by FastAPI and Alembic (service name `db` inside compose)
DATABASE_URL=postgresql+psycopg://nextpost:nextpost@db:5432/nextpost
