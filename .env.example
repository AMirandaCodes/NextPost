# Copy this file to .env and adjust values as needed.
# The defaults below work for local development with docker compose.

# PostgreSQL
POSTGRES_USER=nextpost
POSTGRES_PASSWORD=nextpost
POSTGRES_DB=nextpost

# Backend — connection string used by FastAPI and Alembic (service name `db` inside compose)
DATABASE_URL=postgresql+psycopg://nextpost:nextpost@db:5432/nextpost

# Auth — generate a real key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-key
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Email reminders — defaults point at the Mailpit dev container (inbox: http://localhost:8025).
# For a real provider set host/port/credentials and SMTP_STARTTLS=true.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false
EMAIL_FROM=NextPost <no-reply@nextpost.local>

# Production only (docker-compose.prod.yml) — host port nginx is published on.
# In production also set a strong POSTGRES_PASSWORD and a real SMTP provider above.
HTTP_PORT=80

# Portfolio demo mode (ADR 0014) — off by default. When true, POST /auth/demo
# issues sessions for a shared demo account whose data resets on an interval.
# The public Render deployment sets: DEMO_MODE=true, REMINDERS_ENABLED=false.
DEMO_MODE=false
REMINDERS_ENABLED=true
